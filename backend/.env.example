# ── BowlSmart Backend — Environment Variables ──
# Copy this file to .env and fill in the values.

# Google Gemini API key (optional — falls back to rule-based reports if missing)
GEMINI_API_KEY=

# Upload directory (default: backend/uploads)
# UPLOAD_DIR=uploads

# Video constraints
# MAX_VIDEO_SIZE_MB=100
# MAX_VIDEO_DURATION_SEC=30

# Target FPS for frame extraction (default: 10)
# TARGET_FPS=10

# Supabase (for user auth + data persistence)
# Get from: Supabase Dashboard → Settings → API
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_KEY=your-service-role-key-here
